# Arbitrage Finder - Configuration

# API Keys (get from respective services if needed)
EBAY_API_KEY=
GOOGLE_TRENDS_API_KEY=

# Proxy configuration (optional, for avoiding IP blocks)
USE_PROXY=false
PROXY_LIST=

# Shipping defaults
DEFAULT_SHIPPING_METHOD_CHINA=epacket
DEFAULT_SHIPPING_METHOD_JAPAN=registered_airmail

# Profit thresholds
MIN_PROFIT_MARGIN_PERCENT=30
MIN_PROFIT_DOLLAR=10

# Search settings
TIMEOUT_SECONDS=10
MAX_RETRIES=3
RATE_LIMIT_SECONDS=2

# Output settings
OUTPUT_FORMAT=json
SAVE_RESULTS=true
RESULTS_FILE=results.json
